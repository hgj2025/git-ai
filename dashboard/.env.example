# ── 数据库 ────────────────────────────────────────────
POSTGRES_DB=gitai_dashboard
POSTGRES_USER=gitai
POSTGRES_PASSWORD=changeme_strong_password

# Grafana 只读账号（由 schema.sql 创建）
GRAFANA_DB_PASSWORD=changeme_grafana_password

# ── Grafana ───────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=changeme_admin_password
# 内网部署可开启匿名访问，公网部署请删除下面两行
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer

# ── Collector ─────────────────────────────────────────
COLLECT_INTERVAL_SECONDS=300   # 每 5 分钟采集一次
REPOS_DIR=/data/repos          # 仓库克隆目录（容器内路径）

# ── Git 认证 Token ────────────────────────────────────
# 按需填写，与 repos.yaml 中的 token_env 对应
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN_INFRA=ghp_yyyyyyyy   # 多 token 示例
