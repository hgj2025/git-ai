{
  "uid": "team-ai-code",
  "title": "Team AI Code Dashboard",
  "description": "团队 AI 代码产出统计 · Powered by git-ai",
  "tags": ["git-ai", "team", "ai"],
  "timezone": "browser",
  "refresh": "1h",
  "schemaVersion": 38,
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "annotations": { "list": [] },

  "templating": {
    "list": [
      {
        "name": "repo",
        "label": "仓库",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "gitai-postgres" },
        "query": "SELECT name FROM repos ORDER BY name",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "developer",
        "label": "开发者",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "gitai-postgres" },
        "query": "SELECT DISTINCT commit_author_email FROM commit_metrics WHERE commit_author_email IS NOT NULL ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "title": "AI 生成行数（周期内）",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT SUM(total_ai_additions) FROM commit_metrics WHERE $__timeFilter(committed_at)",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "displayName": "AI 生成行"
        }
      }
    },

    {
      "id": 2,
      "title": "直接接受行数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT SUM(accepted_lines) FROM commit_metrics WHERE $__timeFilter(committed_at)",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "displayName": "接受行"
        }
      }
    },

    {
      "id": 3,
      "title": "AI 接受率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT ROUND(SUM(accepted_lines)::numeric / NULLIF(SUM(total_ai_additions),0) * 100, 1) FROM commit_metrics WHERE $__timeFilter(committed_at)",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green",  "value": 65 }
            ]
          },
          "unit": "percent",
          "displayName": "接受率 %"
        }
      }
    },

    {
      "id": 4,
      "title": "活跃开发者数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(DISTINCT commit_author_email) FROM commit_metrics WHERE $__timeFilter(committed_at) AND total_ai_additions > 0",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short",
          "displayName": "活跃开发者"
        }
      }
    },

    {
      "id": 5,
      "title": "追踪仓库数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) FROM repos",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "short",
          "displayName": "仓库"
        }
      }
    },

    {
      "id": 6,
      "title": "AI 辅助 Commit 数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) FROM commit_metrics WHERE $__timeFilter(committed_at) AND total_ai_additions > 0",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "displayName": "AI Commits"
        }
      }
    },

    {
      "id": 10,
      "title": "每日 AI 代码量趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  date_trunc('day', committed_at) AS time,\n  repo_name,\n  SUM(total_ai_additions) AS ai_generated\nFROM commit_metrics\nWHERE $__timeFilter(committed_at)\n  AND ('$repo' = '.*' OR repo_name = ANY(string_to_array('$repo', ',')))\nGROUP BY 1, 2\nORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "unit": "short",
          "displayName": "${__field.labels.repo_name}"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 11,
      "title": "AI 接受率趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  date_trunc('day', committed_at) AS time,\n  ROUND(\n    SUM(accepted_lines)::numeric / NULLIF(SUM(total_ai_additions),0) * 100, 1\n  ) AS acceptance_rate\nFROM commit_metrics\nWHERE $__timeFilter(committed_at)\n  AND ('$repo' = '.*' OR repo_name = ANY(string_to_array('$repo', ',')))\nGROUP BY 1\nORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },

    {
      "id": 20,
      "title": "AI 工具使用分布",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  tool,\n  SUM(total_additions) AS lines\nFROM prompt_metrics pm\nJOIN commit_metrics cm USING (repo_name, commit_sha)\nWHERE $__timeFilter(cm.committed_at)\n  AND ('$repo' = '.*' OR cm.repo_name = ANY(string_to_array('$repo', ',')))\nGROUP BY tool\nORDER BY lines DESC",
          "format": "table"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 21,
      "title": "AI 模型使用分布",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  model,\n  SUM(total_additions) AS lines\nFROM prompt_metrics pm\nJOIN commit_metrics cm USING (repo_name, commit_sha)\nWHERE $__timeFilter(cm.committed_at)\n  AND ('$repo' = '.*' OR cm.repo_name = ANY(string_to_array('$repo', ',')))\nGROUP BY model\nORDER BY lines DESC",
          "format": "table"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 22,
      "title": "各模型接受率对比",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  tool || ' / ' || model AS tool_model,\n  ROUND(SUM(accepted_lines)::numeric / NULLIF(SUM(total_additions),0) * 100, 1) AS acceptance_rate\nFROM prompt_metrics pm\nJOIN commit_metrics cm USING (repo_name, commit_sha)\nWHERE $__timeFilter(cm.committed_at)\nGROUP BY tool, model\nHAVING SUM(total_additions) > 10\nORDER BY acceptance_rate DESC",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green",  "value": 65 }
            ]
          }
        }
      }
    },

    {
      "id": 30,
      "title": "开发者 AI 贡献排行",
      "type": "table",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  commit_author_email                                           AS \"开发者\",\n  COUNT(DISTINCT repo_name)                                     AS \"仓库数\",\n  COUNT(*)                                                      AS \"AI Commits\",\n  SUM(total_ai_additions)                                       AS \"AI 生成行\",\n  SUM(accepted_lines)                                           AS \"直接接受行\",\n  ROUND(SUM(accepted_lines)::numeric/NULLIF(SUM(total_ai_additions),0)*100,1) AS \"接受率%\",\n  SUM(overridden_lines)                                         AS \"修改后接受行\"\nFROM commit_metrics\nWHERE $__timeFilter(committed_at)\n  AND total_ai_additions > 0\n  AND ('$developer' = '.*' OR commit_author_email = ANY(string_to_array('$developer', ',')))\nGROUP BY commit_author_email\nORDER BY \"AI 生成行\" DESC\nLIMIT 50",
          "format": "table"
        }
      ],
      "options": { "sortBy": [{ "displayName": "AI 生成行", "desc": true }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "接受率%" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":40},{"color":"green","value":65}] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },

    {
      "id": 31,
      "title": "仓库 AI 使用概览",
      "type": "table",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 20 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  repo_name                                                     AS \"仓库\",\n  COUNT(DISTINCT commit_author_email)                           AS \"开发者\",\n  COUNT(*)                                                      AS \"AI Commits\",\n  SUM(total_ai_additions)                                       AS \"AI 生成行\",\n  SUM(accepted_lines)                                           AS \"接受行\",\n  ROUND(SUM(accepted_lines)::numeric/NULLIF(SUM(total_ai_additions),0)*100,1) AS \"接受率%\"\nFROM commit_metrics\nWHERE $__timeFilter(committed_at)\nGROUP BY repo_name\nORDER BY \"AI 生成行\" DESC",
          "format": "table"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "接受率%" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":40},{"color":"green","value":65}] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },

    {
      "id": 40,
      "title": "AI 高密度文件榜（Top 20）",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  repo_name     AS \"仓库\",\n  file_path     AS \"文件\",\n  total_ai_lines AS \"AI 归属行\",\n  touched_by_commits AS \"涉及 Commits\"\nFROM v_hot_files\nWHERE ('$repo' = '.*' OR repo_name = ANY(string_to_array('$repo', ',')))\nORDER BY total_ai_lines DESC\nLIMIT 20",
          "format": "table"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "AI 归属行" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color":"blue","value":null},{"color":"purple","value":200},{"color":"red","value":500}] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },

    {
      "id": 41,
      "title": "Collector 采集状态",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "postgres", "uid": "gitai-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  repo_name              AS \"仓库\",\n  last_collected_at      AS \"最后采集时间\",\n  total_commits_processed AS \"已处理 Commits\",\n  CASE WHEN last_error IS NOT NULL THEN '❌ ' || last_error ELSE '✅ 正常' END AS \"状态\"\nFROM collector_state\nORDER BY last_collected_at DESC NULLS LAST",
          "format": "table"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "最后采集时间" },
            "properties": [{ "id": "unit", "value": "dateTimeFromNow" }]
          }
        ]
      }
    }

  ]
}
